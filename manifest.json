{
  "name": "Tabs to Markdown V2",
  "version": "2.0",
  "manifest_version": 3,
  "description": "Refreshes all tabs and then copies their titles and URLs to the clipboard as Markdown.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "permissions": ["offscreen", "clipboardWrite", "tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
